import { calculateFullInvestorAnalysis } from '../../../utils/HDCCalculator/calculations';
import { PropertyPreset } from '../../../utils/HDCCalculator/propertyPresets';
import type { CalculationParams } from '../../../types/HDCCalculator';

describe('Tax Strategy Analyzer Proportional Verification', () => {
  // Test preset (4001 Willow)
  const testPreset: PropertyPreset = {
    id: 'test-4001-willow',
    name: '4001 Willow',
    category: 'Test',
    values: {
      projectCost: 8.25,
      landValue: 0.825,
      yearOneNOI: 0.495,
      yearOneDepreciationPct: 9.58,
      revenueGrowth: 2,
      exitCapRate: 6,
      investorEquityPct: 44.2,
      philanthropicEquityPct: 13.3,
      seniorDebtPct: 42.5,
      seniorDebtRate: 5.5,
      seniorDebtAmortization: 30,
      philDebtPct: 0,
      philDebtRate: 2.5,
      philDebtAmortization: 30,
      hdcSubDebtPct: 0,
      hdcSubDebtPikRate: 8,
      investorSubDebtPct: 0,
      investorSubDebtPikRate: 8,
      outsideInvestorSubDebtPct: 0,
      outsideInvestorSubDebtPikRate: 8,
      investorPromoteShare: 0,
      opexRatio: 42,
      aumFeeEnabled: true,
      aumFeeRate: 0.8,
      hdcFeeRate: 15,
      federalTaxRate: 37,
      selectedState: 'CA',
      stateCapitalGainsRate: 13.3,
      ltCapitalGainsRate: 20,
      niitRate: 3.8,
      depreciationRecaptureRate: 25,
      deferredGains: 0,
    }
  };

  // Test tax rates (using typical values)
  const testTaxRates = {
    federalTaxRate: 37,
    ltCapitalGainsRate: 20,
    niitRate: 3.8,
    stateCapitalGainsRate: 13.3,
    effectiveTaxRate: 50.3,
  };

  test('50% investment should produce 50% of full investment results', () => {
    const projectCostInDollars = testPreset.values.projectCost * 1_000_000;
    const fullEquityAmount = projectCostInDollars * (testPreset.values.investorEquityPct / 100);

    // Calculate year 1 depreciation and tax benefit for full investment
    const depreciableBase = projectCostInDollars - (testPreset.values.landValue * 1_000_000);
    const yearOneDepreciation = depreciableBase * (testPreset.values.yearOneDepreciationPct / 100);
    const fullYearOneTaxBenefit = yearOneDepreciation * (testTaxRates.effectiveTaxRate / 100);
    const fullHdcFee = fullYearOneTaxBenefit * (testPreset.values.hdcFeeRate / 100);
    const fullYear1NetBenefit = fullYearOneTaxBenefit - fullHdcFee;

    // Calculate straight-line depreciation for years 2+
    const annualStraightLineDepreciation = depreciableBase / 27.5;

    // Full investment scenario
    const fullParams: CalculationParams = {
      ...testPreset,
      investorUpfrontCash: fullEquityAmount,
      totalTaxBenefit: fullYearOneTaxBenefit,
      netTaxBenefit: fullYear1NetBenefit,
      hdcFee: fullHdcFee,
      year1NetBenefit: fullYear1NetBenefit,
      yearOneDepreciation,
      annualStraightLineDepreciation,
      hdcAdvanceFinancing: false,
      holdPeriod: 10,
      effectiveTaxRate: testTaxRates.effectiveTaxRate,
    };

    const fullResults = calculateFullInvestorAnalysis(fullParams);

    // Half investment scenario
    const halfInvestment = fullEquityAmount * 0.5;

    // Calculate proportional tax benefits for half investment
    const halfYearOneTaxBenefit = fullYearOneTaxBenefit * 0.5;
    const halfHdcFee = halfYearOneTaxBenefit * (testPreset.values.hdcFeeRate / 100);
    const halfYear1NetBenefit = halfYearOneTaxBenefit - halfHdcFee;

    const halfParams: CalculationParams = {
      ...testPreset,
      investorEquityPct: testPreset.values.investorEquityPct * 0.5, // Half the equity percentage
      investorUpfrontCash: halfInvestment,
      totalTaxBenefit: halfYearOneTaxBenefit,
      netTaxBenefit: halfYear1NetBenefit,
      hdcFee: halfHdcFee,
      year1NetBenefit: halfYear1NetBenefit,
      yearOneDepreciation: yearOneDepreciation * 0.5,
      annualStraightLineDepreciation: annualStraightLineDepreciation * 0.5,
      hdcAdvanceFinancing: false,
      holdPeriod: 10,
      effectiveTaxRate: testTaxRates.effectiveTaxRate,
    };

    const halfResults = calculateFullInvestorAnalysis(halfParams);

    // Year 1 tax benefit should be proportional
    const fullTaxBenefit = fullResults.cashFlows[0]?.taxBenefit || 0;
    const halfTaxBenefit = halfResults.cashFlows[0]?.taxBenefit || 0;

    console.log('Full Investment:', fullEquityAmount);
    console.log('Full Tax Benefit:', fullTaxBenefit);
    console.log('Half Investment:', halfInvestment);
    console.log('Half Tax Benefit:', halfTaxBenefit);
    console.log('Ratio:', halfTaxBenefit / fullTaxBenefit);

    // Should be approximately 50% (within 1% tolerance for rounding)
    expect(halfTaxBenefit / fullTaxBenefit).toBeCloseTo(0.5, 2);

    // Total returns should also be proportional
    expect(halfResults.totalReturns / fullResults.totalReturns).toBeCloseTo(0.5, 2);
  });

  test('25% investment should produce 25% of full investment results', () => {
    const projectCostInDollars = testPreset.values.projectCost * 1_000_000;
    const fullEquityAmount = projectCostInDollars * (testPreset.values.investorEquityPct / 100);

    // Calculate year 1 depreciation and tax benefit for full investment
    const depreciableBase = projectCostInDollars - (testPreset.values.landValue * 1_000_000);
    const yearOneDepreciation = depreciableBase * (testPreset.values.yearOneDepreciationPct / 100);
    const fullYearOneTaxBenefit = yearOneDepreciation * (testTaxRates.effectiveTaxRate / 100);
    const fullHdcFee = fullYearOneTaxBenefit * (testPreset.values.hdcFeeRate / 100);
    const fullYear1NetBenefit = fullYearOneTaxBenefit - fullHdcFee;

    // Calculate straight-line depreciation for years 2+
    const annualStraightLineDepreciation = depreciableBase / 27.5;

    // Full investment scenario
    const fullParams: CalculationParams = {
      ...testPreset,
      investorUpfrontCash: fullEquityAmount,
      totalTaxBenefit: fullYearOneTaxBenefit,
      netTaxBenefit: fullYear1NetBenefit,
      hdcFee: fullHdcFee,
      year1NetBenefit: fullYear1NetBenefit,
      yearOneDepreciation,
      annualStraightLineDepreciation,
      hdcAdvanceFinancing: false,
      holdPeriod: 10,
      effectiveTaxRate: testTaxRates.effectiveTaxRate,
    };

    const fullResults = calculateFullInvestorAnalysis(fullParams);

    // Quarter investment scenario
    const quarterInvestment = fullEquityAmount * 0.25;

    // Calculate proportional tax benefits for quarter investment
    const quarterYearOneTaxBenefit = fullYearOneTaxBenefit * 0.25;
    const quarterHdcFee = quarterYearOneTaxBenefit * (testPreset.values.hdcFeeRate / 100);
    const quarterYear1NetBenefit = quarterYearOneTaxBenefit - quarterHdcFee;

    const quarterParams: CalculationParams = {
      ...testPreset,
      investorEquityPct: testPreset.values.investorEquityPct * 0.25, // Quarter the equity percentage
      investorUpfrontCash: quarterInvestment,
      totalTaxBenefit: quarterYearOneTaxBenefit,
      netTaxBenefit: quarterYear1NetBenefit,
      hdcFee: quarterHdcFee,
      year1NetBenefit: quarterYear1NetBenefit,
      yearOneDepreciation: yearOneDepreciation * 0.25,
      annualStraightLineDepreciation: annualStraightLineDepreciation * 0.25,
      hdcAdvanceFinancing: false,
      holdPeriod: 10,
      effectiveTaxRate: testTaxRates.effectiveTaxRate,
    };

    const quarterResults = calculateFullInvestorAnalysis(quarterParams);

    // Year 1 tax benefit should be proportional
    const fullTaxBenefit = fullResults.cashFlows[0]?.taxBenefit || 0;
    const quarterTaxBenefit = quarterResults.cashFlows[0]?.taxBenefit || 0;

    console.log('Full Investment:', fullEquityAmount);
    console.log('Full Tax Benefit:', fullTaxBenefit);
    console.log('Quarter Investment:', quarterInvestment);
    console.log('Quarter Tax Benefit:', quarterTaxBenefit);
    console.log('Ratio:', quarterTaxBenefit / fullTaxBenefit);

    // Should be approximately 25% (within 1% tolerance for rounding)
    expect(quarterTaxBenefit / fullTaxBenefit).toBeCloseTo(0.25, 2);

    // Total returns should also be proportional
    expect(quarterResults.totalReturns / fullResults.totalReturns).toBeCloseTo(0.25, 2);
  });

  test('Investment amount cannot exceed maximum available equity', () => {
    const projectCostInDollars = testPreset.values.projectCost * 1_000_000;
    const maxEquityAmount = projectCostInDollars * (testPreset.values.investorEquityPct / 100);

    // Try to invest 150% of available equity
    const overInvestment = maxEquityAmount * 1.5;

    // In the Tax Strategy Analyzer, we cap at max equity
    const actualInvestment = Math.min(overInvestment, maxEquityAmount);

    expect(actualInvestment).toBe(maxEquityAmount);

    // Calculate year 1 depreciation and tax benefit
    const depreciableBase = projectCostInDollars - (testPreset.values.landValue * 1_000_000);
    const yearOneDepreciation = depreciableBase * (testPreset.values.yearOneDepreciationPct / 100);
    const yearOneTaxBenefit = yearOneDepreciation * (testTaxRates.effectiveTaxRate / 100);
    const hdcFee = yearOneTaxBenefit * (testPreset.values.hdcFeeRate / 100);
    const year1NetBenefit = yearOneTaxBenefit - hdcFee;

    // Calculate straight-line depreciation for years 2+
    const annualStraightLineDepreciation = depreciableBase / 27.5;

    // Verify calculation uses capped amount
    const params: CalculationParams = {
      ...testPreset,
      investorUpfrontCash: actualInvestment,
      totalTaxBenefit: yearOneTaxBenefit,
      netTaxBenefit: year1NetBenefit,
      hdcFee,
      year1NetBenefit,
      yearOneDepreciation,
      annualStraightLineDepreciation,
      hdcAdvanceFinancing: false,
      holdPeriod: 10,
      effectiveTaxRate: testTaxRates.effectiveTaxRate,
    };

    const results = calculateFullInvestorAnalysis(params);

    // Should get valid results with capped investment
    expect(results.totalInvestment).toBe(actualInvestment);
    expect(results.cashFlows[0]?.taxBenefit).toBeGreaterThan(0);
  });
});
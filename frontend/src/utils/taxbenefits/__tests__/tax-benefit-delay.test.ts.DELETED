import { calculateFullInvestorAnalysis } from '../calculations';
import type { CalculationParams } from '../../../types/HDCCalculator';

describe('Tax Benefit Delay Feature', () => {
  const baseParams: CalculationParams = {
    projectCost: 10,
    landValue: 1,
    yearOneNOI: 0.6,
    yearOneDepreciationPct: 20,
    revenueGrowth: 3,
    expenseGrowth: 3,
    exitCapRate: 6,
    investorEquityPct: 30,
    hdcFeeRate: 15,
    hdcAdvanceFinancing: false,
    investorUpfrontCash: 3,
    totalTaxBenefit: 0.9,
    netTaxBenefit: 0.765,
    hdcFee: 0.135,
    year1NetBenefit: 0.765,
    investorPromoteShare: 0,
    opexRatio: 40,
    holdPeriod: 10,
    yearOneDepreciation: 1.8,
    annualStraightLineDepreciation: 0.26,
    effectiveTaxRate: 50,
    taxBenefitDelayMonths: 0,
    constructionDelayMonths: 0,  };

  test('No delay - benefits received immediately', () => {
    const results = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 0,
    constructionDelayMonths: 0,    });

    // Year 1 should have full tax benefit
    // Depreciable basis = 10 - 1 (land) - 3 (investor equity) = 6
    // Year 1 depreciation = 6 × 20% = 1.2
    // Gross tax benefit = 1.2 × 50% = 0.6
    // HDC fee = 0.6 × 15% = 0.09
    // Net to investor = 0.6 - 0.09 = 0.51
    expect(results.cashFlows[0].taxBenefit).toBeCloseTo(0.64, 2);
    expect(results.cashFlows[0].taxBenefit).toBeGreaterThan(0);
  });

  test('12-month delay - benefits start in Year 2', () => {
    const results = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 12,
    constructionDelayMonths: 0,    });

    // Year 1 should have no tax benefit (delayed)
    expect(results.cashFlows[0].taxBenefit).toBe(0);

    // Year 2 should have accumulated Year 1 benefit (0.51) + Year 2 current benefit (~0.11)
    // This creates the expected "big bump" in Year 2
    expect(results.cashFlows[1].taxBenefit).toBeCloseTo(0.62, 2);

    // Verify Year 3 has only current year benefit (no accumulation)
    expect(results.cashFlows[2].taxBenefit).toBeCloseTo(0.11, 2);
  });

  test('24-month delay - benefits start in Year 3', () => {
    const results = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 24,
    constructionDelayMonths: 0,    });

    // Years 1 and 2 should have no tax benefit (delayed)
    expect(results.cashFlows[0].taxBenefit).toBe(0);
    expect(results.cashFlows[1].taxBenefit).toBe(0);

    // Year 3 should have accumulated benefits from Year 1 (0.51) + Year 2 (~0.11) + Year 3 (~0.11)
    // This creates the expected "big bump" in Year 3 = 0.73
    expect(results.cashFlows[2].taxBenefit).toBeCloseTo(0.73, 2);

    // Verify Year 4 has only current year benefit (no accumulation)
    expect(results.cashFlows[3].taxBenefit).toBeCloseTo(0.11, 2);
  });

  test('6-month delay - full Year 1 benefit (delay < 12 months)', () => {
    const results = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 6,
    constructionDelayMonths: 0,    });

    // Year 1 should have FULL benefit even with 6-month delay
    // Delays < 12 months only affect timing within the year, not the total amount
    // The investor still files taxes for Year 1 and gets the full refund
    expect(results.cashFlows[0].taxBenefit).toBeCloseTo(0.64, 2);
    expect(results.cashFlows[0].taxBenefit).toBeGreaterThan(0);
  });

  test('IRR should decrease with longer delays', () => {
    const noDelayResults = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 0,
    constructionDelayMonths: 0,    });

    const oneYearDelayResults = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 12,
    constructionDelayMonths: 0,    });

    const twoYearDelayResults = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 24,
    constructionDelayMonths: 0,    });

    // IRR should decrease as delay increases
    expect(noDelayResults.irr).toBeGreaterThanOrEqual(oneYearDelayResults.irr);
    expect(oneYearDelayResults.irr).toBeGreaterThan(twoYearDelayResults.irr);
  });

  test('Total benefits over hold period should remain constant', () => {
    const noDelayResults = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 0,
    constructionDelayMonths: 0,    });

    const oneYearDelayResults = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 12,
    constructionDelayMonths: 0,    });

    // Total tax benefits should be approximately the same
    const noDelayTotal = noDelayResults.cashFlows.reduce((sum, cf) => sum + cf.taxBenefit, 0);
    const delayedTotal = oneYearDelayResults.cashFlows.reduce((sum, cf) => sum + cf.taxBenefit, 0);

    // They should be close but not exactly equal due to the delay shifting benefits
    expect(Math.abs(noDelayTotal - delayedTotal)).toBeLessThan(1);
  });

  test('HDC advance financing should provide immediate benefit despite delay', () => {
    const withAdvanceResults = calculateFullInvestorAnalysis({
      ...baseParams,
      taxBenefitDelayMonths: 24,
    constructionDelayMonths: 0,      hdcAdvanceFinancing: true,
    });

    // With HDC advance financing, Year 1 should still have benefit (same as no delay)
    // HDC provides upfront cash to investor despite the delay
    expect(withAdvanceResults.cashFlows[0].taxBenefit).toBeCloseTo(0.64, 2);

    // Years 2-3 should have no benefits since HDC already provided the advance
    // (The accumulation logic doesn't apply when HDC provides advance financing)
    expect(withAdvanceResults.cashFlows[1].taxBenefit).toBe(0);
    expect(withAdvanceResults.cashFlows[2].taxBenefit).toBe(0);
  });
});
/**
 * Six Sigma Tax Benefits Validation - Trace 4001
 *
 * STEP 6 TAX BENEFITS VALIDATION
 *
 * Independent calculation verification using Trace 4001 parameters.
 * All calculations verified against hand-calculated values with ±0.1% accuracy requirement.
 *
 * Trace 4001 Parameters:
 * - Project Cost: $67M
 * - Land Value: $6.7M (10%)
 * - Investor Equity: 5%
 * - Cost Seg: 20% (updated 2025 standard)
 * - Oregon Tax Rates:
 *   - Ordinary Income: 37% federal + 9.9% state = 46.9%
 *   - Capital Gains: 20% federal + 3.8% NIIT + 9.9% state = 33.7%
 * - OZ Type: Standard (10% step-up)
 * - Placed in Service: July (month 7)
 */

import { calculateFullInvestorAnalysis } from '../../calculations';
import { CalculationParams } from '../../../../types/HDCCalculator';

describe('Six Sigma Tax Benefits Validation - Trace 4001', () => {

  const TRACE_4001_PARAMS: Partial<CalculationParams> = {
    projectCost: 67, // $67M
    landValue: 6.7, // $6.7M (10%)
    yearOneNOI: 3.5, // $3.5M
    investorEquityPct: 5, // 5%
    yearOneDepreciationPct: 20, // 20% cost seg (2025 standard)
    effectiveTaxRate: 46.9, // 37% federal + 9.9% Oregon
    hdcFeeRate: 10, // 10% (will be eliminated post-Vegas)
    placedInServiceMonth: 7, // July

    // OZ parameters
    ozEnabled: true,
    ozType: 'standard', // 10% step-up
    deferredCapitalGains: 10, // $10M deferred gains
    ltCapitalGainsRate: 20, // Federal LTCG
    niitRate: 3.8, // NIIT
    stateCapitalGainsRate: 9.9, // Oregon state cap gains
    capitalGainsTaxRate: 33.7, // Combined: 20 + 3.8 + 9.9

    // Debt structure (simplified for tax focus)
    seniorDebtPct: 66,
    philanthropicDebtPct: 20,
    hdcSubDebtPct: 2,
    investorSubDebtPct: 2.5,
    seniorDebtRate: 5,
    seniorDebtAmortization: 35,
    seniorDebtIOYears: 3,
    hdcSubDebtPikRate: 8,
    investorSubDebtPikRate: 8,

    holdPeriod: 10,
    revenueGrowth: 3,
    expenseGrowth: 3,
    exitCapRate: 6,
  };

  describe('Depreciable Basis - QCG Exclusion', () => {
    it('should correctly exclude investor equity (QCGs) from depreciable basis', () => {
      const result = calculateFullInvestorAnalysis(TRACE_4001_PARAMS as CalculationParams);

      // Hand calculation:
      // Total Project Cost: $67M
      // Interest Reserve: ~$0 (simplified)
      // Effective Project Cost: $67M
      // Investor Equity (5%): $67M × 0.05 = $3.35M
      // Depreciable Basis: $67M - $6.7M (land) - $3.35M (QCG) = $56.95M

      const expectedDepreciableBasis = 67 - 6.7 - (67 * 0.05);
      const calculatedDepreciableBasis = expectedDepreciableBasis; // $56.95M

      // Verify via Year 1 depreciation backwards calculation
      // Year 1 includes: 20% bonus + partial straight-line
      // Bonus: $56.95M × 0.20 = $11.39M
      // Remaining: $56.95M × 0.80 = $45.56M
      // Annual MACRS: $45.56M / 27.5 = $1.657M
      // Year 1 MACRS (July, 5.5 months): $1.657M × (5.5/12) = $0.760M
      // Total Year 1 Depreciation: $11.39M + $0.760M = $12.15M

      const expectedBonusDepreciation = calculatedDepreciableBasis * 0.20;
      const expectedRemainingBasis = calculatedDepreciableBasis * 0.80;
      const expectedAnnualMACRS = expectedRemainingBasis / 27.5;
      const expectedYear1MACRS = expectedAnnualMACRS * (5.5 / 12); // July = 5.5 months
      const expectedYear1TotalDepreciation = expectedBonusDepreciation + expectedYear1MACRS;

      // Tolerance: ±0.1% (six sigma accuracy)
      const tolerance = expectedYear1TotalDepreciation * 0.001;

      // Get actual Year 1 depreciation from results
      const actualYear1Flow = result.investorCashFlows[0];

      // Verify depreciable basis via tax benefit calculation
      // Tax Benefit = Depreciation × Tax Rate
      // Depreciation = Tax Benefit / (Tax Rate - HDC Fee Rate)
      // Gross Tax Benefit = Net Tax Benefit / (1 - HDC Fee %)
      const netTaxBenefit = actualYear1Flow.taxBenefit;
      const hdcFeePaid = actualYear1Flow|| 0;
      const grossTaxBenefit = netTaxBenefit + hdcFeePaid;
      const actualDepreciation = grossTaxBenefit / (TRACE_4001_PARAMS.effectiveTaxRate! / 100);

      expect(actualDepreciation).toBeGreaterThan(expectedYear1TotalDepreciation - tolerance);
      expect(actualDepreciation).toBeLessThan(expectedYear1TotalDepreciation + tolerance);
    });
  });

  describe('Year 1 Tax Benefit Calculation', () => {
    it('should calculate Year 1 tax benefits with six sigma accuracy', () => {
      const result = calculateFullInvestorAnalysis(TRACE_4001_PARAMS as CalculationParams);

      // Independent calculation:
      // Depreciable Basis: $56.95M
      // Bonus Depreciation (20%): $11.39M
      // Remaining Basis: $45.56M
      // Annual MACRS: $1.657M
      // Year 1 MACRS (5.5 months): $0.760M
      // Total Year 1 Depreciation: $12.15M
      // Gross Tax Benefit: $12.15M × 0.469 = $5.698M
      // HDC Fee (10%): $0.570M
      // Net Tax Benefit: $5.128M

      const depreciableBasis = 67 - 6.7 - (67 * 0.05); // $56.95M
      const bonusDepreciation = depreciableBasis * 0.20; // $11.39M
      const remainingBasis = depreciableBasis * 0.80; // $45.56M
      const annualMACRS = remainingBasis / 27.5; // $1.657M
      const year1MACRS = annualMACRS * (5.5 / 12); // $0.760M
      const totalDepreciation = bonusDepreciation + year1MACRS; // $12.15M

      const grossTaxBenefit = totalDepreciation * (TRACE_4001_PARAMS.effectiveTaxRate! / 100);
      const hdcFee = grossTaxBenefit * 0.10;
      const netTaxBenefit = grossTaxBenefit - hdcFee;

      const year1Flow = result.investorCashFlows[0];

      // Six sigma accuracy: ±0.1%
      const tolerance = 0.001;

      expect(year1Flow.taxBenefit).toBeCloseTo(netTaxBenefit, 2);
      // REMOVED: expect(0).toBeCloseTo(hdcFee, 2);

      // Verify ±0.1% accuracy
      const netBenefitError = Math.abs(year1Flow.taxBenefit - netTaxBenefit) / netTaxBenefit;
      const hdcFeeError = Math.abs((year1Flow|| 0) - hdcFee) / hdcFee;

      expect(netBenefitError).toBeLessThan(tolerance);
      expect(hdcFeeError).toBeLessThan(tolerance);
    });

    it('should use ordinary income tax rate for depreciation benefits', () => {
      const result = calculateFullInvestorAnalysis(TRACE_4001_PARAMS as CalculationParams);

      // Verify that depreciation benefits use 46.9% (ordinary income rate)
      // NOT 33.7% (capital gains rate)

      const year1Flow = result.investorCashFlows[0];
      const grossTaxBenefit = year1Flow.taxBenefit + (year1Flow|| 0);

      // Back-calculate the effective rate used
      // Depreciation = Gross Tax Benefit / Tax Rate
      // We know the tax benefit, so we can verify the rate

      // The gross benefit should be roughly proportional to the ordinary income rate (46.9%)
      // If capital gains rate (33.7%) was used, the benefit would be ~28% lower

      const ordinaryRateBenefit = grossTaxBenefit;
      const capitalGainsRateBenefit = grossTaxBenefit * (33.7 / 46.9); // Would be ~72% of actual

      // Verify the benefit is consistent with ordinary income rate
      // If cap gains rate was used, benefit would be significantly lower
      expect(grossTaxBenefit).toBeGreaterThan(capitalGainsRateBenefit * 1.2);
    });
  });

  describe('HDC 10% Fee Calculation', () => {
    it('should apply 10% fee to gross tax benefit', () => {
      const result = calculateFullInvestorAnalysis(TRACE_4001_PARAMS as CalculationParams);

      const year1Flow = result.investorCashFlows[0];
      const netTaxBenefit = year1Flow.taxBenefit;
      const hdcFee = year1Flow|| 0;
      const grossTaxBenefit = netTaxBenefit + hdcFee;

      // HDC fee should be 10% of gross
      const expectedHdcFee = grossTaxBenefit * 0.10;

      // Six sigma accuracy
      expect(hdcFee).toBeCloseTo(expectedHdcFee, 3);

      // Investor should receive 90% of gross
      const expectedNetBenefit = grossTaxBenefit * 0.90;
      expect(netTaxBenefit).toBeCloseTo(expectedNetBenefit, 3);
    });
  });

  describe('Years 2-10 Straight-Line Depreciation', () => {
    it('should calculate straight-line depreciation for Years 2-10', () => {
      const result = calculateFullInvestorAnalysis(TRACE_4001_PARAMS as CalculationParams);

      // Calculate expected annual straight-line
      const depreciableBasis = 67 - 6.7 - (67 * 0.05); // $56.95M
      const bonusDepreciation = depreciableBasis * 0.20; // $11.39M
      const remainingBasis = depreciableBasis - bonusDepreciation; // $45.56M
      const annualStraightLine = remainingBasis / 27.5; // $1.657M per year

      // Check Years 2-10 (indices 1-9)
      for (let year = 2; year <= 10; year++) {
        const yearFlow = result.investorCashFlows[year - 1];

        // Tax benefit should be consistent with straight-line depreciation
        const grossTaxBenefit = yearFlow.taxBenefit + (yearFlow|| 0);
        const impliedDepreciation = grossTaxBenefit / (TRACE_4001_PARAMS.effectiveTaxRate! / 100);

        // Should be close to annual straight-line amount
        // Tolerance: ±2% (allows for minor calculation differences)
        const tolerance = annualStraightLine * 0.02;

        expect(impliedDepreciation).toBeGreaterThan(annualStraightLine - tolerance);
        expect(impliedDepreciation).toBeLessThan(annualStraightLine + tolerance);
      }
    });
  });

  describe('Cost Seg Default Verification', () => {
    it('should use 20% as the default cost seg percentage (2025 standard)', () => {
      // This test verifies that when no yearOneDepreciationPct is specified,
      // the system uses 20% (not the old 25% standard)

      const paramsWithoutCostSeg = { ...TRACE_4001_PARAMS };
      delete paramsWithoutCostSeg.yearOneDepreciationPct;

      const result = calculateFullInvestorAnalysis(paramsWithoutCostSeg as CalculationParams);

      // Calculate expected with 20%
      const depreciableBasis = 67 - 6.7 - (67 * 0.05); // $56.95M
      const expectedBonusAt20 = depreciableBasis * 0.20; // $11.39M
      const remainingBasis = depreciableBasis * 0.80; // $45.56M
      const annualMACRS = remainingBasis / 27.5;
      const year1MACRS = annualMACRS * (5.5 / 12);
      const totalDepreciation = expectedBonusAt20 + year1MACRS;

      // If 25% was used, bonus would be $14.24M (25% higher)
      const expectedBonusAt25 = depreciableBasis * 0.25;

      const year1Flow = result.investorCashFlows[0];
      const grossTaxBenefit = year1Flow.taxBenefit + (year1Flow|| 0);
      const actualDepreciation = grossTaxBenefit / (TRACE_4001_PARAMS.effectiveTaxRate! / 100);

      // Should be much closer to 20% than 25%
      const diffFrom20 = Math.abs(actualDepreciation - totalDepreciation);
      const diffFrom25 = Math.abs(actualDepreciation - (expectedBonusAt25 + year1MACRS));

      expect(diffFrom20).toBeLessThan(diffFrom25);
    });
  });
});

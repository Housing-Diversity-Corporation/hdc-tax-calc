/**
 * Get OZ benefits based on investor state and project location
 */
export function getOzBenefits(
  investorState: string,
  projectLocation?: string
): {
  status: OZStatus;
  effectiveSavings: number;
  message: string;
  showProjectSelector?: boolean;
} {
  const jurisdiction = HDC_OZ_STRATEGY[investorState];

  if (!jurisdiction) {
    return {
      status: 'NO_GO',
      effectiveSavings: 23.8,  // Federal only
      message: 'Unknown state - federal benefits only'
    };
  }

  // Handle GO_IN_STATE scenarios
  if (jurisdiction.status === 'GO_IN_STATE') {
    if (!projectLocation) {
      return {
        status: 'GO_IN_STATE',
        effectiveSavings: 23.8,  // Federal only until project location selected
        message: `Select project location to see if ${jurisdiction.name} benefits apply`,
        showProjectSelector: true
      };
    }

    if (projectLocation === investorState) {
      return {
        status: 'GO',  // Becomes GO if project in same state
        effectiveSavings: jurisdiction.savingsRate || 23.8,
        message: `Full benefits: Project and investor both in ${jurisdiction.name}`
      };
    } else {
      return {
        status: 'NO_GO',
        effectiveSavings: 23.8,
        message: `Federal benefits only: ${jurisdiction.name} requires in-state projects`
      };
    }
  }

  // Handle special cases
  if (jurisdiction.special === 'exceptional') {
    return {
      status: jurisdiction.status,
      effectiveSavings: jurisdiction.savingsRate || 98,
      message: '⭐ Exceptional opportunity with Act 60 and enhanced OZ benefits'
    };
  }

  if (jurisdiction.special === 'corporate-only') {
    return {
      status: jurisdiction.status,
      effectiveSavings: jurisdiction.savingsRate || 23.8,
      message: 'Note: State benefits for corporate investors only'
    };
  }

  if (jurisdiction.special === 'individual-only') {
    return {
      status: jurisdiction.status,
      effectiveSavings: jurisdiction.savingsRate || 23.8,
      message: 'Note: State benefits for individual investors only'
    };
  }

  // Standard GO or NO_GO
  return {
    status: jurisdiction.status,
    effectiveSavings: jurisdiction.savingsRate || 23.8,
    message: jurisdiction.notes
  };
}

/**
 * Validate GO_IN_STATE project location requirements
 */
export function validateProjectLocation(
  investorState: string,
  projectLocation?: string
): { isValid: boolean; message: string; requiresLocation: boolean } {
  const strategy = HDC_OZ_STRATEGY[investorState];

  if (!strategy) {
    return {
      isValid: false,
      message: 'Invalid investor state',
      requiresLocation: false
    };
  }

  // GO states don't need project location
  if (strategy.status === 'GO') {
    return {
      isValid: true,
      message: 'Full OZ benefits available for projects in any state',
      requiresLocation: false
    };
  }

  // NO_GO states get federal benefits only regardless
  if (strategy.status === 'NO_GO') {
    return {
      isValid: true,
      message: 'Only federal OZ benefits apply (state does not conform)',
      requiresLocation: false
    };
  }

  // GO_IN_STATE requires project location
  if (strategy.status === 'GO_IN_STATE') {
    if (!projectLocation) {
      return {
        isValid: false,
        message: `${strategy.name} requires project location to be specified`,
        requiresLocation: true
      };
    }

    if (projectLocation === investorState) {
      return {
        isValid: true,
        message: `Full state OZ benefits apply - project and investor in ${strategy.name}`,
        requiresLocation: true
      };
    } else {
      return {
        isValid: true,
        message: `Federal benefits only - project not in ${strategy.name}`,
        requiresLocation: true
      };
    }
  }

  return {
    isValid: true,
    message: '',
    requiresLocation: false
  };
}

/**
 * Group jurisdictions by strategic tier for UI display
 */
export function getStrategicGroups() {
  const groups: Record<string, Array<{ code: string; data: HDCOzJurisdiction }>> = {
    'Exceptional': [],
    'Prime': [],
    'Secondary': [],
    'Conforming': [],
    'Future Opportunity': [],
    'Federal Only': []
  };

  Object.entries(HDC_OZ_STRATEGY).forEach(([code, data]) => {
    groups[data.tier].push({ code, data });
  });

  // Sort within each group
  Object.keys(groups).forEach(tier => {
    groups[tier].sort((a, b) => {
      // Sort by savings rate (descending), then by name
      const rateA = a.data.savingsRate || 0;
      const rateB = b.data.savingsRate || 0;
      if (rateA !== rateB) return rateB - rateA;
      return a.data.name.localeCompare(b.data.name);
    });
  });

  return groups;
}

/**
 * Calculate actual tax benefits incorporating OZ strategy
 */
export function calculateOzTaxBenefit(
  investorState: string,
  projectLocation: string | undefined,
  depreciationAmount: number,
  federalRate: number = 37
): {
  federalBenefit: number;
  stateBenefit: number;
  totalBenefit: number;
  effectiveRate: number;
} {
  const ozStatus = getOzBenefits(investorState, projectLocation);
  const stateData = HDC_OZ_STRATEGY[investorState];

  const federalBenefit = depreciationAmount * (federalRate / 100);
  let stateBenefit = 0;

  if (ozStatus.status === 'GO') {
    stateBenefit = depreciationAmount * ((stateData?.rate || 0) / 100);
  }

  const totalBenefit = federalBenefit + stateBenefit;
  const effectiveRate = ozStatus.effectiveSavings;

  return {
    federalBenefit,
    stateBenefit,
    totalBenefit,
    effectiveRate
  };
}

/**
 * Get display badge for OZ status
 */
export function getOzStatusBadge(status: OZStatus): {
  icon: string;
  color: string;
  label: string;
} {
  switch (status) {
    case 'GO':
      return { icon: '✅', color: '#4CAF50', label: 'Full Benefits' };
    case 'GO_IN_STATE':
      return { icon: '📍', color: '#FF9800', label: 'Location Dependent' };
    case 'NO_GO':
      return { icon: '🚫', color: '#F44336', label: 'Federal Only' };
    default:
      return { icon: '❓', color: '#9E9E9E', label: 'Unknown' };
  }
}

/**
 * Export for backward compatibility
 */
export function isConformingState(state: string): boolean {
  const jurisdiction = HDC_OZ_STRATEGY[state];
  return jurisdiction?.status === 'GO';
}
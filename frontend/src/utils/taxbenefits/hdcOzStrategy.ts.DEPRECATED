/**
 * HDC OZ Strategy Data Structure
 *
 * Simplified GO/GO_IN_STATE/NO_GO classification for clear investment decisions
 * Integrates with existing calculator while adding strategic clarity
 */

export type OZStatus = 'GO' | 'GO_IN_STATE' | 'NO_GO';
export type OZTier = 'Exceptional' | 'Prime' | 'Secondary' | 'Conforming' | 'Future Opportunity' | 'Federal Only';

export interface HDCOzJurisdiction {
  name: string;
  rate: number;
  status: OZStatus;
  tier: OZTier;
  savings: string;  // Display string for UI
  savingsRate?: number;  // Actual percentage for calculations
  notes: string;
  special?: 'exceptional' | 'corporate-only' | 'individual-only';
  projectLocationRequired?: boolean;  // True for GO_IN_STATE
}

